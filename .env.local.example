# Anthropic — get this from console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the model used for insight generation (default: claude-opus-4-5)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Supabase — get these from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — get this from resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# The verified sender email in your Resend account
RESEND_FROM_EMAIL=results@yourdomain.com
RESEND_FROM_NAME=Founder Fit

# Your deployed URL (used for internal API calls in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
